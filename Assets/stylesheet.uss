:root {
}

/* ── Fullscreen dark background ── */
.screen {
    flex-grow: 1;
    background-color: rgb(18, 16, 12);
    align-items: center;
    justify-content: center;
}

/* ── Panel card ── */
.panel {
    background-color: rgba(30, 27, 20, 0.92);
    border-width: 1px;
    border-color: rgba(85, 75, 50, 0.4);
    border-radius: 6px;
    padding: 32px;
}

/* ── Typography ── */
.title-text {
    font-size: 72px;
    color: rgb(200, 180, 120);
    -unity-text-align: upper-center;
    -unity-font-style: bold;
    letter-spacing: 10px;
    margin-bottom: 8px;
}

.subtitle-text {
    font-size: 13px;
    color: rgba(200, 180, 120, 0.45);
    -unity-text-align: upper-center;
    letter-spacing: 6px;
    margin-bottom: 56px;
}

.heading-text {
    font-size: 30px;
    color: rgb(200, 180, 120);
    -unity-text-align: upper-center;
    -unity-font-style: bold;
    letter-spacing: 4px;
    margin-bottom: 28px;
}

.label-text {
    font-size: 18px;
    color: rgb(210, 200, 170);
    letter-spacing: 2px;
    -unity-font-style: bold;
}

/* ── Buttons ── */
.button {
    height: 56px;
    font-size: 20px;
    width: 280px;
    background-color: rgba(50, 45, 30, 0.8);
    border-width: 1px;
    border-color: rgba(120, 105, 65, 0.4);
    border-radius: 4px;
    color: rgb(210, 200, 170);
    -unity-font-style: bold;
    padding: 12px 24px;
    margin: 5px 0;
    letter-spacing: 3px;
    transition-duration: 0.15s;
}

.button:hover {
    background-color: rgba(70, 62, 40, 0.9);
    border-color: rgba(200, 180, 120, 0.6);
    color: rgb(230, 210, 150);
}

.button:active {
    background-color: rgba(85, 75, 48, 0.95);
    scale: 0.97;
}

.button-small {
    height: 42px;
    font-size: 15px;
    background-color: rgba(50, 45, 30, 0.8);
    border-width: 1px;
    border-color: rgba(120, 105, 65, 0.4);
    border-radius: 3px;
    color: rgb(210, 200, 170);
    -unity-font-style: bold;
    padding: 8px 20px;
    letter-spacing: 2px;
    transition-duration: 0.15s;
}

.button-small:hover {
    background-color: rgba(70, 62, 40, 0.9);
    border-color: rgba(200, 180, 120, 0.6);
    color: rgb(230, 210, 150);
}

.button-small:active {
    scale: 0.97;
}

.button-accent {
    background-color: rgba(120, 105, 65, 0.5);
    border-color: rgba(200, 180, 120, 0.6);
    color: rgb(200, 180, 120);
}

.button-accent:hover {
    background-color: rgba(145, 128, 78, 0.65);
    border-color: rgb(230, 210, 150);
    color: rgb(230, 210, 150);
}

.button-stepper {
    width: 36px;
    height: 36px;
    font-size: 20px;
    background-color: rgba(50, 45, 30, 0.8);
    border-width: 1px;
    border-color: rgba(120, 105, 65, 0.4);
    border-radius: 3px;
    color: rgb(200, 180, 120);
    -unity-font-style: bold;
    padding: 0;
    transition-duration: 0.15s;
}

.button-stepper:hover {
    background-color: rgba(70, 62, 40, 0.9);
    border-color: rgba(200, 180, 120, 0.6);
}

/* ── Divider ── */
.divider {
    height: 1px;
    background-color: rgba(85, 75, 50, 0.35);
    margin-top: 16px;
    margin-bottom: 16px;
}

/* ── Settings text (legacy compat) ── */
.SettingsText {
    font-size: 18px;
    color: rgb(210, 200, 170);
    letter-spacing: 2px;
}

/* ── Toggle styling ── */
#Container > #Background > #Settings > #Private > .unity-toggle__input {
    justify-content: flex-end;
}

.unity-toggle__input > .unity-toggle__checkmark {
    background-color: rgba(50, 45, 30, 0.8);
    border-color: rgba(120, 105, 65, 0.5);
    -unity-background-image-tint-color: rgb(200, 180, 120);
}

/* ── Code entry slots ── */
.code-slot {
    width: 52px;
    height: 66px;
    margin: 0 5px;
    background-color: rgba(40, 36, 25, 0.9);
    border-width: 1px;
    border-color: rgba(120, 105, 65, 0.4);
    border-radius: 4px;
    font-size: 34px;
    color: rgb(230, 210, 150);
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    transition-duration: 0.12s;
}

.code-slot-active {
    border-color: rgb(200, 180, 120);
    background-color: rgba(55, 49, 33, 0.95);
}

.code-hint {
    font-size: 11px;
    color: rgba(200, 180, 120, 0.4);
    letter-spacing: 4px;
    margin-bottom: 24px;
}

.code-hidden-field {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    opacity: 0;
    margin: 0;
}

/* ── Input field styling ── */
.unity-text-field__input,
.unity-integer-field__input {
    background-color: rgba(40, 36, 25, 0.9);
    border-width: 1px;
    border-color: rgba(120, 105, 65, 0.4);
    border-radius: 3px;
    color: rgb(200, 180, 120);
    font-size: 28px;
    padding: 10px 16px;
    -unity-text-align: middle-center;
    letter-spacing: 8px;
}

.unity-text-field__input:focus,
.unity-integer-field__input:focus {
    border-color: rgb(200, 180, 120);
}

/* ── ScrollView ── */
.unity-scroll-view {
    background-color: rgba(15, 13, 10, 0.4);
    border-radius: 4px;
    border-width: 1px;
    border-color: rgba(85, 75, 50, 0.25);
}

.unity-scroller--vertical > .unity-slider > .unity-base-slider__tracker {
    background-color: rgba(50, 45, 30, 0.4);
}

.unity-scroller--vertical > .unity-slider > .unity-base-slider__dragger {
    background-color: rgba(200, 180, 120, 0.35);
    border-radius: 3px;
}

/* ── In-game HUD ── */
.crosshair {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 4px;
    height: 4px;
    margin-left: -2px;
    margin-top: -2px;
    border-radius: 2px;
    background-color: rgba(230, 210, 150, 0.75);
}

.stamina-bar {
    position: absolute;
    bottom: 42px;
    left: 50%;
    margin-left: -140px;
    width: 280px;
    height: 6px;
    background-color: rgba(15, 13, 10, 0.75);
    border-width: 1px;
    border-color: rgba(120, 105, 65, 0.5);
    border-radius: 3px;
    transition-property: opacity;
    transition-duration: 0.4s;
}

.stamina-fill {
    height: 100%;
    width: 100%;
    background-color: rgb(200, 180, 120);
    border-radius: 2px;
}

.hints {
    position: absolute;
    bottom: 24px;
    left: 24px;
}

.hint-text {
    font-size: 12px;
    color: rgba(200, 180, 120, 0.35);
    letter-spacing: 2px;
    margin-bottom: 2px;
}

/* ── Camcorder overlay ── */
.cam-overlay {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
}

.cam-corner {
    position: absolute;
    width: 46px;
    height: 46px;
    border-color: rgba(225, 225, 225, 0.65);
}

.cam-corner-tl {
    top: 36px;
    left: 48px;
    border-top-width: 2px;
    border-left-width: 2px;
}

.cam-corner-tr {
    top: 36px;
    right: 48px;
    border-top-width: 2px;
    border-right-width: 2px;
}

.cam-corner-bl {
    bottom: 36px;
    left: 48px;
    border-bottom-width: 2px;
    border-left-width: 2px;
}

.cam-corner-br {
    bottom: 36px;
    right: 48px;
    border-bottom-width: 2px;
    border-right-width: 2px;
}

.cam-rec-row {
    position: absolute;
    top: 46px;
    left: 70px;
    flex-direction: row;
    align-items: center;
}

.cam-rec-dot {
    width: 14px;
    height: 14px;
    border-radius: 7px;
    background-color: rgb(225, 45, 35);
    margin-right: 9px;
}

.cam-rec-text {
    font-size: 20px;
    color: rgb(235, 235, 235);
    letter-spacing: 4px;
    -unity-font-style: bold;
}

.cam-time {
    position: absolute;
    top: 48px;
    right: 70px;
    font-size: 18px;
    color: rgb(235, 235, 235);
    letter-spacing: 3px;
    -unity-font-style: bold;
}

.cam-bottom-row {
    position: absolute;
    bottom: 46px;
    right: 70px;
    flex-direction: row;
    align-items: center;
}

.cam-meta-text {
    font-size: 13px;
    color: rgba(235, 235, 235, 0.7);
    letter-spacing: 2px;
    margin-right: 14px;
}

.cam-battery {
    flex-direction: row;
    align-items: center;
    height: 16px;
    border-width: 1px;
    border-color: rgba(235, 235, 235, 0.7);
    border-radius: 2px;
    padding: 2px 3px;
}

.cam-battery-bar {
    width: 6px;
    height: 8px;
    background-color: rgba(235, 235, 235, 0.85);
    margin-right: 2px;
}

.cam-battery-bar-dim {
    background-color: rgba(235, 235, 235, 0.2);
    margin-right: 0;
}

/* ── Inventory overlay ── */
.inventory-overlay {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(8, 7, 5, 0.72);
    align-items: center;
    justify-content: center;
}

.inventory-panel {
    width: 470px;
    padding: 24px 28px;
}

.inventory-header {
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 18px;
}

.inventory-title {
    font-size: 22px;
    color: rgb(200, 180, 120);
    letter-spacing: 6px;
    -unity-font-style: bold;
}

.inventory-count {
    font-size: 14px;
    color: rgba(200, 180, 120, 0.5);
    letter-spacing: 2px;
}

.inventory-grid {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
}

.inv-slot {
    width: 92px;
    height: 92px;
    margin: 4px;
    background-color: rgba(40, 36, 25, 0.85);
    border-width: 1px;
    border-color: rgba(85, 75, 50, 0.5);
    border-radius: 4px;
    align-items: center;
    justify-content: center;
    transition-duration: 0.12s;
}

.inv-slot:hover {
    background-color: rgba(55, 49, 33, 0.9);
    border-color: rgba(200, 180, 120, 0.7);
}

.inv-slot-filled {
    border-color: rgba(200, 180, 120, 0.5);
}

.inv-slot-empty {
    font-size: 10px;
    color: rgba(200, 180, 120, 0.18);
    letter-spacing: 2px;
}

.inv-slot-item {
    font-size: 12px;
    color: rgb(230, 210, 150);
    letter-spacing: 1px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    white-space: normal;
}

.inventory-hint {
    margin-top: 16px;
    font-size: 11px;
    color: rgba(200, 180, 120, 0.35);
    letter-spacing: 4px;
    -unity-text-align: middle-center;
}

/* ── Pause menu ── */
.pause-overlay {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(8, 7, 5, 0.78);
    align-items: center;
    justify-content: center;
}

.pause-columns {
    flex-direction: row;
    align-items: flex-start;
}

.pause-panel {
    width: 320px;
    padding: 28px;
    margin: 0 10px;
}

.pause-panel > .button {
    width: auto;
    align-self: stretch;
}

.pause-title {
    font-size: 26px;
    color: rgb(200, 180, 120);
    letter-spacing: 8px;
    -unity-font-style: bold;
    -unity-text-align: middle-center;
    margin-bottom: 20px;
}

.option-label {
    font-size: 12px;
    color: rgba(200, 180, 120, 0.55);
    letter-spacing: 3px;
    margin-top: 10px;
    margin-bottom: 2px;
}

.pause-panel .unity-base-slider__tracker {
    height: 4px;
    border-radius: 2px;
    background-color: rgba(50, 45, 30, 0.9);
    border-color: rgba(120, 105, 65, 0.4);
}

.pause-panel .unity-base-slider__dragger {
    width: 14px;
    height: 14px;
    border-radius: 7px;
    border-width: 0;
    background-color: rgb(200, 180, 120);
}

.players-panel {
    width: 260px;
    padding: 24px;
    margin: 0 10px;
}

.players-header {
    flex-direction: row;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 12px;
}

.players-title {
    font-size: 16px;
    color: rgb(200, 180, 120);
    letter-spacing: 4px;
    -unity-font-style: bold;
}

.players-count {
    font-size: 14px;
    color: rgba(200, 180, 120, 0.5);
    letter-spacing: 2px;
}

.player-row {
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    background-color: rgba(40, 36, 25, 0.85);
    border-width: 1px;
    border-color: rgba(85, 75, 50, 0.5);
    border-radius: 3px;
    padding: 8px 10px;
    margin-bottom: 4px;
}

.player-name {
    font-size: 13px;
    color: rgb(210, 200, 170);
    letter-spacing: 2px;
}

.player-you {
    font-size: 10px;
    color: rgba(200, 180, 120, 0.6);
    letter-spacing: 2px;
}
